# Alpine (OpenRC, musl) — the non-systemd matrix slot.
#
# Purpose: prove clearance's hub/verdict (varlink over manually-bound
# unix sockets) and the desktop-notification fallback work on a host
# with NO systemd at all — the OpenRC/runit/s6 and SLURM-job floor.
# See terok-ai/terok#959 and #1113.  clearance was already varlink-only
# (no systemd socket activation); this slot keeps that honest in CI.
#
# Deliberately does NOT install systemd.  The run-matrix.sh preflight
# asserts systemd is absent here.  D-Bus (session bus) is installed so
# the notification path and dbusmock fixtures can exercise the "bus
# present" case; the headless "no bus" case is covered by unit tests.
#
# The musl build toolchain is required: dbus-python (pulled in by
# python-dbusmock) has no musllinux wheel and is built from source via
# meson against dbus-dev + glib-dev.  uv provides a fast,
# ensurepip-independent venv; its official-image binary is static musl.
FROM docker.io/library/alpine:3.21

RUN apk add --no-cache \
    dbus \
    shadow \
    build-base python3-dev dbus-dev glib-dev pkgconf meson libffi-dev \
    python3 \
    git curl ca-certificates bash

COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

RUN useradd -m -s /bin/bash testrunner
WORKDIR /src
