# Fedora 43 — dbus + dunst, system Python 3.12+
FROM registry.fedoraproject.org/fedora:43

RUN dnf install -y \
    dbus \
    python3 python3-pip \
    git curl \
    && dnf clean all

RUN useradd -m testrunner
WORKDIR /src
