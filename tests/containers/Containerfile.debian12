# Debian 12 (Bookworm) — dbus + dbusmock deps, Python 3.12 via uv
FROM docker.io/library/debian:12

# Ownership label: a Containerfile LABEL propagates into every
# intermediate layer image, so the harness teardown can prune exactly
# its own dangling generations (value = the harness IMAGE_PREFIX).
LABEL "io.terok.matrix-test"="terok-clearance-test"

RUN apt-get update && apt-get install -y --no-install-recommends \
    dbus \
    gcc python3-dev libdbus-1-dev libglib2.0-dev pkg-config meson \
    python3 \
    git curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Debian 12 ships Python 3.11 — use uv to get 3.12+
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv
RUN uv python install 3.12

RUN useradd -m testrunner
WORKDIR /src
